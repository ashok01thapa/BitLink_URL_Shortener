@Library('Shared') _
pipeline {
    agent { label 'bitlink_agent' }
    environment {
        SONAR_HOME = tool "Sonar"
    }
    parameters {
        string(name: 'DOCKER_TAG', defaultValue: '', description: 'Setting docker image for latest push')
    }
    stages {
        stage("Validate Parameters") {
            steps {
                script {
                    if (params.DOCKER_TAG == '') {
                        error("DOCKER_TAG must be provided.")
                    }
                }
            }
        }
        stage("Workspace cleanup"){
            steps{
                script{
                    cleanWs()
                }
            }
        }
        stage('Git: Code Checkout') {
            steps {
                script{
                    code_checkout("https://github.com/ashok01thapa/bit_links.git", "main")
                }
            }
        }
        stage("Trivy: Filesystem scan"){
            steps{
                script{
                    trivy_scan()
                }
            }
        }
        stage('Free Memory') {
            steps {
                sh 'sync; echo 3 | sudo tee /proc/sys/vm/drop_caches || true; free -h'
            }
        }
        stage("OWASP: Dependency check"){
            steps{
                script{
                    owasp_dependency()
                }
            }
        }
        stage("SonarQube: Code Analysis"){
            steps{
                script{
                    sonarqube_analysis("Sonar", "bitlinks", "bitlinks")
                }
            }
        }
        stage("SonarQube: Code Quality Gates"){
            steps{
                script{
                    catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                        sonarqube_code_quality()
                    }
                }
            }
        }
        stage("Install Dependencies") {
            steps {
                sh 'NODE_OPTIONS="--max-old-space-size=512" npm ci --prefer-offline --no-audit --no-fund'
            }
        }
        stage("Docker: Build Image"){
            steps{
                script{
                    docker_build("bitlinks-app", "${params.DOCKER_TAG}", "ashokthapa", "http://3.130.138.12:3000", "MONGODB_URI")
                }
            }
        }
        stage("Docker: Push to DockerHub"){
            steps{
                script{
                    docker_push("bitlinks-app", "${params.DOCKER_TAG}", "ashokthapa")
                }
            }
        }
    }
    post {
        success {
            archiveArtifacts artifacts: '*.xml', followSymlinks: false
            build job: "Bitlinks_CD", parameters: [
                string(name: 'DOCKER_TAG', value: "${params.DOCKER_TAG}")
            ]
        }
        failure {
            echo "Pipeline failed at build #${env.BUILD_NUMBER}. Check the stage logs above for details."
            archiveArtifacts artifacts: '*.xml', allowEmptyArchive: true, followSymlinks: false
        }
    }
}